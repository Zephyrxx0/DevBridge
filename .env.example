# GCP Configuration
# Required for Vertex AI / Gemini API access

# Project & Location
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us-central1

# Authentication (choose one method)

# Method 1: Service Account Key File (recommended for local dev)
GOOGLE_APPLICATION_CREDENTIALS=./config/service-account-key.json

# Vertex AI flow does not require GOOGLE_API_KEY.

# Method 2: For local development with gcloud auth
# Run: gcloud auth application-default login
# Then leave GOOGLE_APPLICATION_CREDENTIALS unset or empty

# Vertex AI Model Configuration
VERTEX_AI_MODEL=gemini-1.5-flash
VERTEX_AI_temperature=0.7

# Backend Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000

# Secrets Management
SUPABASE_CONNECTION_STRING=
